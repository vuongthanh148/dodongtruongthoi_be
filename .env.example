# App Configuration
APP_NAME=dodongtruongthoi-be
APP_ENV=development
PORT=8080

# JWT Secret (MUST change in production to a strong random value)
JWT_SECRET=dev-secret-change-in-production

# Database (PostgreSQL - REQUIRED)
# ============================================
# Format: postgres://USERNAME:PASSWORD@HOST:PORT/DBNAME
#
# For local development with direct psql:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/dodongtruongthoi
#
# For docker-compose (use this, DATABASE_URL is auto-overridden in compose):
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/dodongtruongthoi
#
# For production (use strong credentials, not defaults):
#   DATABASE_URL=postgres://prod_user:STRONG_PASSWORD@prod-host:5432/prod_dbname
# ============================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dodongtruongthoi

# Cloudinary Image Upload (Optional)
# Leave empty to disable image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
